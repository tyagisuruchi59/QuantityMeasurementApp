{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=prod-server;Database=QuantityMeasurementDb;User Id=sa;Password=YourProdPassword;",
    "Redis": "your-redis-host:6379,password=yourredispassword,ssl=true"
  },

  "Database": {
    "UseInMemory": false
  },

  "Jwt": {
    "Key": "REPLACE_WITH_STRONG_PROD_SECRET_AT_LEAST_32_CHARS",
    "Issuer": "QuantityMeasurementApp",
    "Audience": "QuantityMeasurementAppUsers",
    "ExpiryMinutes": "30",
    "RefreshTokenExpiryDays": "3"
  },

  "Security": {
    "Pepper": "REPLACE_WITH_STRONG_PROD_PEPPER",
    "AesKey": "REPLACE_WITH_STRONG_PROD_AES_KEY"
  },

  "Swagger": {
    "Enabled": false
  }
}