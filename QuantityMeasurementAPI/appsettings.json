{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
  "DefaultConnection": "Host=dpg-d7e7rn58nd3s73ba1uh0-a.oregon-postgres.render.com;Port=5432;Database=quantity_measurement_db_o0pd;Username=quantity_measurement_db_o0pd_user;Password=cTTCof2nf7Xn86UNKKC0QpBLwNdqapEO;SSL Mode=Require;Trust Server Certificate=true",
  "Redis": ""
},

  "Database": {
    "UseInMemory": false
  },

  "Jwt": {
    "Key": "YourSuperSecretKey@QuantityMeasurementApp2024!MustBe32CharsMin",
    "Issuer": "QuantityMeasurementApp",
    "Audience": "QuantityMeasurementAppUsers",
    "ExpiryMinutes": "1440",
    "RefreshTokenExpiryDays": "7"
  },

  "Security": {
    "Pepper": "GlobalAppPepper@QMA#2024!SecretPepper",
    "AesKey": "AesEncryptionKey@QMA#2024!MustBe32CharLong"
  },

  "Swagger": {
    "Enabled": true
  },

  "NLog": {
    "autoReload": true,
    "throwConfigExceptions": true,
    "internalLogLevel": "Info",
    "internalLogFile": "${basedir}/logs/internal-nlog.txt",
    "extensions": [
      { "assembly": "NLog.Web.AspNetCore" }
    ],
    "variables": {
      "logdir": "${basedir}/logs"
    },
    "targets": {
      "async": true,
      "all-file": {
        "type": "File",
        "fileName": "${logdir}/QMA-${shortdate}.log",
        "layout": "${longdate}|${event-properties:item=EventId_Id:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}"
      },
      "console": {
        "type": "ColoredConsole",
        "layout": "${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}"
      }
    },
    "rules": [
      {
        "logger": "Microsoft.*",
        "maxLevel": "Info",
        "final": true
      },
      {
        "logger": "*",
        "minLevel": "Debug",
        "writeTo": "all-file,console"
      }
    ]
  }
}